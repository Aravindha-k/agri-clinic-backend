                                        "api",
                                        "v1",
                                        "masters",
                                        "districts",
                                        ""
                                    ]
                                }
                            },
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "type": "text/javascript",
                                        "exec": [
                                            "const res = pm.response.json();",
                                            "if (res && res.id) { pm.environment.set('district_id', res.id); }",
                                            "pm.test('District created', () => pm.response.code === 201);",
                                            "pm.test('district id set', () => pm.environment.get('district_id') !== undefined);"
                                        ]
                                    }
                                }
                            ]
