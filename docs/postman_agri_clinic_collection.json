{
    "info": {
        "name": "Agri Clinic - API Collection",
        "_postman_id": "agri-clinic-collection",
        "description": "Collection for Admin Panel and Mobile employee API endpoints (JWT auth). Use the accompanying environment to set `base_url` and `access_token`.",
