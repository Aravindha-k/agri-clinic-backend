# ============================================================
# Agri Clinic SaaS – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ Environment mode ------
# local | production
APP_ENV=local

# ------ Core Django ------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ------ CORS ------
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ------ Database ------
# Local (leave empty to use sqlite db.sqlite3)
DATABASE_URL=
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ------ Redis ------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------ AWS S3 Storage ------
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=agri-clinic-media
AWS_S3_REGION_NAME=ap-south-1

# ------ JWT ------
# ACCESS_TOKEN_LIFETIME and REFRESH_TOKEN_LIFETIME are set in settings.py
# Override here if needed (values in seconds):
# JWT_ACCESS_SECONDS=43200
# JWT_REFRESH_SECONDS=604800

# ------ Email (future) ------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@agri-clinic.in

# ------ Production toggles (Render) ------
# APP_ENV=production
# DEBUG=False
# CORS_ALLOW_ALL_ORIGINS=false
# ALLOWED_HOSTS=agri-clinic-backend.onrender.com
# CSRF_TRUSTED_ORIGINS=https://agri-clinic-backend.onrender.com
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
