# ============================================================
# Agri Clinic SaaS – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ Core Django ------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
LOG_LEVEL=INFO

# ------ Database (PostgreSQL) ------
DATABASE_URL=postgres://user:password@localhost:5432/agri_clinic

# ------ Redis ------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------ AWS S3 Storage ------
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=agri-clinic-media
AWS_S3_REGION_NAME=ap-south-1

# ------ JWT ------
# ACCESS_TOKEN_LIFETIME and REFRESH_TOKEN_LIFETIME are set in settings.py
# Override here if needed (values in seconds):
# JWT_ACCESS_SECONDS=43200
# JWT_REFRESH_SECONDS=604800

# ------ Email (future) ------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@agri-clinic.in
