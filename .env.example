# ============================================================
# Agri Clinic — Environment (copy to .env for local dev only)
# NEVER commit .env to version control.
# ============================================================

# ------ Environment mode ------
# local | production | render | staging
APP_ENV=local

# ------ Core Django (required on Render) ------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ------ CORS ------
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ------ Database ------
# Local: leave empty to use sqlite (db.sqlite3). Do not point at production DB.
DATABASE_URL=
# Render (auto-injected when linked to Postgres):
# DATABASE_URL=postgresql://user:pass@hostname/dbname
# DB_SSL_REQUIRE=false
# RENDER_POSTGRES_HOST_SUFFIX=  # only if using shortened dpg- host

# ------ Redis (optional — falls back to in-memory cache) ------
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ------ Media storage ------
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# ------ Production example (Render web service) ------
# APP_ENV=production
# DEBUG=False
# SECRET_KEY=<generate-50+-char-random-string>
# ALLOWED_HOSTS=agri-clinic-backend.onrender.com,.onrender.com
# CSRF_TRUSTED_ORIGINS=https://agri-clinic-backend.onrender.com
# CORS_ALLOW_ALL_ORIGINS=false
# CORS_ALLOWED_ORIGINS=https://agri-clinic-frontend.onrender.com
# DATABASE_URL=<from Render Postgres dashboard>
# SECURE_SSL_REDIRECT=true
